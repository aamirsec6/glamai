# GlamAI Environment Configuration
# Copy to .env and fill in real values

# ── Application ──────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
APP_BASE_URL=http://localhost:8000
APP_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://glamai:glamai@localhost:5432/glamai
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=20

# ── LLM (Anthropic Claude) ──────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# LLM Fallback (OpenAI)
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=gpt-4o-mini

# ── WhatsApp Business API (via 360dialog) ───────────────────
WHATSAPP_PROVIDER=360dialog
WHATSAPP_API_KEY=your-360dialog-api-key
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_BUSINESS_ACCOUNT_ID=your-business-account-id
WHATSAPP_API_URL=https://waba-v2.360dialog.io

# ── Google Business Profile API ─────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/gbp/oauth/callback
GOOGLE_PLACES_API_KEY=your-google-places-api-key

# ── Email (Resend) ───────────────────────────────────────────
RESEND_API_KEY=re_xxx
EMAIL_FROM=GlamAI <reports@glamai.in>

# ── File Storage (local for MVP, S3 later) ───────────────────
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=/tmp/glamai/uploads
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# AWS_REGION=ap-south-1

# ── Territory / Exclusivity Defaults ─────────────────────────
TERRITORY_DEFAULT_RADIUS_KM=5.0
TERRITORY_INTERIOR_DESIGN_RADIUS_KM=7.0
TERRITORY_DENTIST_RADIUS_KM=5.0
TERRITORY_SALON_RADIUS_KM=3.0
TERRITORY_GYM_RADIUS_KM=5.0

# ── Feature Flags ────────────────────────────────────────────
FEATURE_REVIEW_ENGINE=false
FEATURE_REENGAGEMENT=false
FEATURE_CONTENT_GENERATOR=false
FEATURE_MULTI_CITY=false
FEATURE_MULTI_VERTICAL=false

# ── API Keys ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
WHATSAPP_360DIALOG_API_KEY=
WHATSAPP_WEBHOOK_SECRET=
GOOGLE_PLACES_API_KEY=
RESEND_API_KEY=
